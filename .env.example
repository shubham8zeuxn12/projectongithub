# MongoDB Connection String
# ──────────────────────────────────────────────────────────────────
# OPTION 1: MongoDB Atlas (Free Cloud — Recommended)
#   1. Go to https://www.mongodb.com/atlas/database
#   2. Create a free account → "Build a Database" → Free M0 tier
#   3. Create a DB user (username + password)
#   4. Whitelist IP: 0.0.0.0/0 (allow all)
#   5. Click "Connect" → "Drivers" → copy the connection string
#   6. Replace <password> with your DB user password below
#
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/annotationdb?retryWrites=true&w=majority
#
# OPTION 2: Local MongoDB (if installed)
# MONGO_URI=mongodb://localhost:27017/annotationdb
#
# If MONGO_URI is not set → app uses in-memory DB (data lost on restart)
# ──────────────────────────────────────────────────────────────────

MONGO_URI=
PORT=3001
